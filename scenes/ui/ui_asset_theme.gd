static func loadTexture(path: String) -> Texture2D:
	var texture := ResourceLoader.load(path) as Texture2D
	if texture == null:
		push_warning("UI texture not found: %s" % path)
	return texture


static func applyPanel(panel: PanelContainer, texturePath: String, textureMargin: float = 38.0, contentMargin: float = 12.0) -> void:
	panel.add_theme_stylebox_override("panel", textureStyle(texturePath, textureMargin, contentMargin))


static func applyTopBarPanel(panel: PanelContainer) -> void:
	applyPanel(panel, PANEL_TOP_BAR_PATH, 42.0, 10.0)


static func applyMainTopBarPanel(panel: PanelContainer) -> void:
	var style := textureStyle(PANEL_MAIN_TOP_BAR_PATH, 30.0, 8.0)
	style.texture_margin_left = 170.0
	style.texture_margin_right = 170.0
	style.texture_margin_top = 30.0
	style.texture_margin_bottom = 30.0
	style.content_margin_left = 170.0
	style.content_margin_right = 170.0
	style.content_margin_top = 8.0
	style.content_margin_bottom = 8.0
	panel.add_theme_stylebox_override("panel", style)


static func applyTextButton(button: Button, danger: bool = false, compact: bool = false) -> void:
	var normalPath := BUTTON_DANGER_PATH if danger else BUTTON_DEFAULT_PATH
	var hoverPath := BUTTON_DANGER_HOVER_PATH if danger else BUTTON_DEFAULT_HOVER_PATH
	var pressedPath := BUTTON_DANGER_PRESSED_PATH if danger else BUTTON_DEFAULT_PRESSED_PATH
	var disabledPath := BUTTON_DANGER_DISABLED_PATH if danger else BUTTON_DEFAULT_DISABLED_PATH
	var contentMargin := 8.0 if compact else 12.0
	button.add_theme_stylebox_override("normal", textureStyle(normalPath, 34.0, contentMargin))
	button.add_theme_stylebox_override("hover", textureStyle(hoverPath, 34.0, contentMargin))
	button.add_theme_stylebox_override("pressed", textureStyle(pressedPath, 34.0, contentMargin))
	button.add_theme_stylebox_override("disabled", textureStyle(disabledPath, 34.0, contentMargin))
	_applyButtonTextTheme(button, 16 if compact else 18, 26 if compact else 30)


static func applyListButton(button: Button, selected: bool = false) -> void:
	var normalPath := LIST_ITEM_SELECTED_PATH if selected else LIST_ITEM_PATH
	button.add_theme_stylebox_override("normal", textureStyle(normalPath, 24.0, 12.0))
	button.add_theme_stylebox_override("hover", textureStyle(LIST_ITEM_SELECTED_PATH, 24.0, 12.0))
	button.add_theme_stylebox_override("pressed", textureStyle(LIST_ITEM_SELECTED_PATH, 24.0, 12.0))
	button.add_theme_stylebox_override("disabled", textureStyle(LIST_ITEM_DISABLED_PATH, 24.0, 12.0))
	_applyButtonTextTheme(button, 16, 28)


static func applyUpgradeButton(button: Button, rarity: String) -> void:
	var cardPath := UPGRADE_CARD_COMMON_PATH
	match rarity:
		"uncommon":
			cardPath = UPGRADE_CARD_UNCOMMON_PATH
		"rare":
			cardPath = UPGRADE_CARD_RARE_PATH
	button.add_theme_stylebox_override("normal", textureStyle(cardPath, 34.0, 16.0))
	button.add_theme_stylebox_override("hover", textureStyle(UPGRADE_CARD_HOVER_PATH, 34.0, 16.0))
	button.add_theme_stylebox_override("pressed", textureStyle(UPGRADE_CARD_SELECTED_PATH, 34.0, 16.0))
	button.add_theme_stylebox_override("disabled", textureStyle(UPGRADE_CARD_DISABLED_PATH, 34.0, 16.0))
	button.alignment = HORIZONTAL_ALIGNMENT_LEFT
	_applyButtonTextTheme(button, 17, 54)


static func applyUpgradeChoiceCardButton(button: Button) -> void:
	var emptyStyle := StyleBoxEmpty.new()
	button.add_theme_stylebox_override("normal", emptyStyle)
	button.add_theme_stylebox_override("hover", emptyStyle)
	button.add_theme_stylebox_override("pressed", emptyStyle)
	button.add_theme_stylebox_override("disabled", emptyStyle)
	button.add_theme_stylebox_override("focus", emptyStyle)
	button.text = ""
	button.icon = null
	button.flat = true
	button.clip_text = true
	button.mouse_default_cursor_shape = Control.CURSOR_POINTING_HAND
	button.add_theme_color_override("font_color", INK_COLOR)
	button.add_theme_color_override("font_hover_color", INK_COLOR)
	button.add_theme_color_override("font_pressed_color", INK_COLOR)
	button.add_theme_color_override("font_hover_pressed_color", INK_COLOR)
	button.add_theme_color_override("font_disabled_color", DISABLED_INK_COLOR)
	button.add_theme_font_size_override("font_size", 16)


static func applyButtonIcon(button: Button, texturePath: String, tooltipText: String = "", maxWidth: int = 30) -> void:
	button.icon = loadTexture(texturePath)
	button.expand_icon = true
	button.icon_alignment = HORIZONTAL_ALIGNMENT_LEFT
	button.add_theme_constant_override("icon_max_width", maxWidth)
	button.add_theme_constant_override("h_separation", 8)
	if tooltipText != "":
		button.tooltip_text = tooltipText


static func applyLabel(label: Label, fontSize: int = 18) -> void:
	label.add_theme_color_override("font_color", INK_COLOR)
	label.add_theme_color_override("font_shadow_color", PAPER_SHADOW_COLOR)
	label.add_theme_constant_override("shadow_offset_x", 1)
	label.add_theme_constant_override("shadow_offset_y", 1)
	label.add_theme_font_size_override("font_size", fontSize)


static func applyTitleLabel(label: Label, fontSize: int = 22) -> void:
	applyLabel(label, fontSize)
	label.add_theme_color_override("font_color", Color("#17130e"))


static func applyCheckbox(checkBox: CheckBox) -> void:
	checkBox.add_theme_icon_override("checked", loadTexture(CHECKBOX_CHECKED_PATH))
	checkBox.add_theme_icon_override("unchecked", loadTexture(CHECKBOX_DEFAULT_PATH))
	checkBox.add_theme_icon_override("checked_disabled", loadTexture(CHECKBOX_DISABLED_PATH))
	checkBox.add_theme_icon_override("unchecked_disabled", loadTexture(CHECKBOX_DISABLED_PATH))
	checkBox.add_theme_color_override("font_color", INK_COLOR)
	checkBox.add_theme_color_override("font_hover_color", INK_COLOR)
	checkBox.add_theme_color_override("font_pressed_color", INK_COLOR)
	checkBox.add_theme_color_override("font_hover_pressed_color", INK_COLOR)
	checkBox.add_theme_color_override("font_disabled_color", DISABLED_INK_COLOR)
	checkBox.add_theme_font_size_override("font_size", 18)


static func applySlider(slider: HSlider) -> void:
	slider.add_theme_stylebox_override("slider", textureStyle(SLIDER_TRACK_PATH, 14.0, 0.0))
	slider.add_theme_stylebox_override("grabber_area", textureStyle(PROGRESS_FILL_PATH, 10.0, 0.0))
	slider.add_theme_stylebox_override("grabber_area_highlight", textureStyle(PROGRESS_FILL_PATH, 10.0, 0.0))
	slider.add_theme_icon_override("grabber", loadTexture(SLIDER_HANDLE_PATH))
	slider.add_theme_icon_override("grabber_highlight", loadTexture(SLIDER_HANDLE_PATH))
	slider.add_theme_icon_override("grabber_disabled", loadTexture(SLIDER_HANDLE_PATH))


static func makeIcon(texturePath: String, size: Vector2) -> TextureRect:
	var icon := TextureRect.new()
	icon.texture = loadTexture(texturePath)
	icon.custom_minimum_size = size
	icon.expand_mode = TextureRect.EXPAND_IGNORE_SIZE
	icon.stretch_mode = TextureRect.STRETCH_KEEP_ASPECT_CENTERED
	icon.mouse_filter = Control.MOUSE_FILTER_IGNORE
	return icon


static func textureStyle(texturePath: String, textureMargin: float, contentMargin: float) -> StyleBoxTexture:
	var style := StyleBoxTexture.new()
	style.texture = loadTexture(texturePath)
	style.texture_margin_left = textureMargin
	style.texture_margin_top = textureMargin
	style.texture_margin_right = textureMargin
	style.texture_margin_bottom = textureMargin
	style.content_margin_left = contentMargin
	style.content_margin_top = contentMargin
	style.content_margin_right = contentMargin
	style.content_margin_bottom = contentMargin
	return style


static func iconForUnit(unitId: StringName) -> String:
	match unitId:
		GameIds.INFANTRY_UNIT_ID:
			return ICON_INFANTRY_PATH
		GameIds.CAVALRY_UNIT_ID:
			return ICON_CAVALRY_PATH
		GameIds.ARTILLERY_UNIT_ID:
			return ICON_ARTILLERY_PATH
		_:
			return ICON_ARMY_PATH


static func iconForArmyStatus(statusText: String) -> String:
	match statusText.to_lower():
		"moving":
			return ICON_STATUS_MOVING_PATH
		"attacking":
			return ICON_STATUS_OFFENSIVE_PATH
		"fighting":
			return ICON_STATUS_FIGHTING_PATH
		"defending":
			return ICON_STATUS_DEFENSIVE_PATH
		"defeated":
			return ICON_STATUS_DEFEATED_PATH
		_:
			return ICON_ARMY_PATH


static func iconForUpgradeEffect(effectType: String) -> String:
	match effectType:
		"recruitmentCostMultiplier":
			return UPGRADE_RECRUITMENT_PATH
		"conquestGoldMultiplier", "startGoldBonus", "countryStartGoldBonus":
			return UPGRADE_GOLD_PATH
		"foodUpkeepMultiplier", "startFoodBonus", "countryStartFoodBonus":
			return UPGRADE_FOOD_PATH
		"defenseCombatMultiplier":
			return UPGRADE_DEFENDER_PATH
		"warThreatMultiplier":
			return UPGRADE_THREAT_PATH
		"countryStartArmyBonus":
			return ICON_INFANTRY_PATH
		"crownRewardMultiplier":
			return ICON_CROWN_PATH
		_:
			return ICON_CONFIRM_PATH


static func _applyButtonTextTheme(button: Button, fontSize: int, iconMaxWidth: int) -> void:
	button.clip_text = true
	button.add_theme_color_override("font_color", INK_COLOR)
	button.add_theme_color_override("font_hover_color", INK_COLOR)
	button.add_theme_color_override("font_pressed_color", INK_COLOR)
	button.add_theme_color_override("font_hover_pressed_color", INK_COLOR)
	button.add_theme_color_override("font_disabled_color", DISABLED_INK_COLOR)
	button.add_theme_font_size_override("font_size", fontSize)
	button.add_theme_constant_override("icon_max_width", iconMaxWidth)
	button.add_theme_constant_override("h_separation", 8)
